<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ .Title }}</title>
  <link rel="stylesheet" href="viewer.css">
</head>
<body>
{{- with .Header }}
<header class="slide-page__header">
{{ . }}
</header>
{{- end }}
<main class="slide-page__main">
  <div class="slide-viewer" id="slide-viewer" data-total="{{ .PageCount }}" tabindex="0">
    <div class="slide-viewer__toolbar">
      <span class="slide-viewer__counter" aria-live="polite">
        <span class="slide-viewer__current">1</span> / {{ .PageCount }}
      </span>
      <div class="slide-viewer__toolbar-actions">
        <button class="slide-viewer__grid-btn" aria-label="Slide overview" title="Grid overview (G)">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="1" y="1" width="6" height="6" rx="1"/><rect x="11" y="1" width="6" height="6" rx="1"/>
            <rect x="1" y="11" width="6" height="6" rx="1"/><rect x="11" y="11" width="6" height="6" rx="1"/>
          </svg>
        </button>
        <button class="slide-viewer__fs-btn" aria-label="Fullscreen" title="Fullscreen (F)">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5">
            <polyline points="6,1 1,1 1,6"/><polyline points="12,1 17,1 17,6"/>
            <polyline points="6,17 1,17 1,12"/><polyline points="12,17 17,17 17,12"/>
          </svg>
        </button>
        {{- if .AllowDownload }}
        <a href="{{ .PDFName }}" class="slide-viewer__download-btn" download
           aria-label="Download PDF" title="Download PDF">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M9 2v10m0 0l-3.5-3.5M9 12l3.5-3.5"/><path d="M2 14v2h14v-2"/>
          </svg>
        </a>
        {{- end }}
      </div>
    </div>

    <div class="slide-viewer__stage">
      <button class="slide-viewer__prev" aria-label="Previous slide" title="Previous (Left arrow)">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <div class="slide-viewer__slides">
{{- range .Slides }}
        <div class="slide-viewer__slide{{ if eq .Index 1 }} slide-viewer__slide--active{{ end }}" data-slide="{{ .Index }}">
          <img src="{{ .Src }}"
               width="{{ .Width }}" height="{{ .Height }}"
               alt="Slide {{ .Index }} of {{ $.Title }}"
               class="slide-viewer__img"
               {{ if le .Index 2 }}loading="eager"{{ else }}loading="lazy"{{ end }}
               decoding="async">
        </div>
{{- end }}
      </div>
      <button class="slide-viewer__next" aria-label="Next slide" title="Next (Right arrow)">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>

    <div class="slide-viewer__grid" hidden aria-label="Slide grid overview">
      <div class="slide-viewer__grid-inner">
{{- range .Slides }}
        <button class="slide-viewer__grid-item" data-slide="{{ .Index }}" aria-label="Go to slide {{ .Index }}">
          <img src="{{ .Src }}" alt="Slide {{ .Index }}" loading="lazy" decoding="async">
          <span class="slide-viewer__grid-num">{{ .Index }}</span>
        </button>
{{- end }}
      </div>
    </div>
  </div>
</main>
{{- with .Footer }}
<footer class="slide-page__footer">
{{ . }}
</footer>
{{- end }}
<script src="viewer.js" defer></script>
</body>
</html>
